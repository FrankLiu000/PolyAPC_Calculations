&GLOBAL
  PROJECT Mg0001_3x3x4
  RUN_TYPE GEO_OPT
  PRINT_LEVEL MEDIUM
&END GLOBAL
&FORCE_EVAL
  METHOD QS
    &DFT
      BASIS_SET_FILE_NAME BASIS_MOLOPT
      POTENTIAL_FILE_NAME GTH_POTENTIALS
      CHARGE 0
      &MGRID
        CUTOFF 400
        REL_CUTOFF 50
      &END MGRID
      &QS
        EPS_DEFAULT 1.0E-12
      &END QS
      &SCF
        SCF_GUESS ATOMIC
        EPS_SCF 1.0E-5
        MAX_SCF 60
        &OT ON
          MINIMIZER DIIS
          PRECONDITIONER FULL_SINGLE_INVERSE
        &END OT
        &OUTER_SCF ON
          MAX_SCF 20
          EPS_SCF 1.0E-5
        &END OUTER_SCF
      &SMEAR ON
        METHOD FERMI_DIRAC
        ELECTRONIC_TEMPERATURE [K] 500
      &END SMEAR
      ADDED_MOS 120
      &END SCF
      &XC
        &XC_FUNCTIONAL PBE
        &END XC_FUNCTIONAL
        &VDW_POTENTIAL
          POTENTIAL_TYPE PAIR_POTENTIAL
          &PAIR_POTENTIAL
            TYPE DFTD3
            PARAMETER_FILE_NAME dftd3.dat
            REFERENCE_FUNCTIONAL PBE
          &END PAIR_POTENTIAL
        &END VDW_POTENTIAL
      &END XC
    &END DFT
    &PRINT
      &V_HARTREE_CUBE
        STRIDE 2 2 1
      &END V_HARTREE_CUBE
    &END PRINT
    &PROPERTIES
      &RESP OFF
      &END RESP
    &END PROPERTIES
    ! libvori/Bader: run with -bader or post-process ELECTRON_DENSITY_CUBE
    &PRINT
      &E_DENSITY_CUBE
        STRIDE 2 2 2
      &END E_DENSITY_CUBE
    &END PRINT
    &SUBSYS
      @INCLUDE 'Mg0001_3x3x4.coord.inc'
      &KIND Mg
        BASIS_SET DZVP-MOLOPT-SR-GTH
        POTENTIAL GTH-PBE-q2
      &END KIND
    &END SUBSYS
&END FORCE_EVAL
&MOTION
  &GEO_OPT
    OPTIMIZER BFGS
    MAX_ITER 300
  &END GEO_OPT
  &CONSTRAINT
    &FIXED_ATOMS
      ! fix bottom two Mg layers (set indices on node from the slab geometry)
      LIST 1..18
    &END FIXED_ATOMS
  &END CONSTRAINT
&END MOTION
