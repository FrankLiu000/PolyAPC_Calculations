&GLOBAL
  PROJECT MgO
  RUN_TYPE BAND
  PRINT_LEVEL MEDIUM
&END GLOBAL
&FORCE_EVAL
  METHOD QS
    &DFT
      BASIS_SET_FILE_NAME BASIS_MOLOPT
      POTENTIAL_FILE_NAME GTH_POTENTIALS
      CHARGE 0
      &MGRID
        CUTOFF 400
        REL_CUTOFF 50
      &END MGRID
      &QS
        EPS_DEFAULT 1.0E-12
      &END QS
      &SCF
        SCF_GUESS ATOMIC
        EPS_SCF 1.0E-5
        MAX_SCF 60
        &OT ON
          MINIMIZER DIIS
          PRECONDITIONER FULL_SINGLE_INVERSE
        &END OT
        &OUTER_SCF ON
          MAX_SCF 20
          EPS_SCF 1.0E-5
        &END OUTER_SCF
      &END SCF
      &XC
        &XC_FUNCTIONAL PBE
        &END XC_FUNCTIONAL
        &VDW_POTENTIAL
          POTENTIAL_TYPE PAIR_POTENTIAL
          &PAIR_POTENTIAL
            TYPE DFTD3
            PARAMETER_FILE_NAME dftd3.dat
            REFERENCE_FUNCTIONAL PBE
          &END PAIR_POTENTIAL
        &END VDW_POTENTIAL
      &END XC
    &END DFT
    &SUBSYS
      ! &CELL + &KIND filled on node (supercell of the SEI phase)
      &KIND Mg
        BASIS_SET DZVP-MOLOPT-SR-GTH
        POTENTIAL GTH-PBE-q2
      &END KIND
      &KIND O
        BASIS_SET DZVP-MOLOPT-SR-GTH
        POTENTIAL GTH-PBE-q6
      &END KIND
    &END SUBSYS
&END FORCE_EVAL
&MOTION
  &BAND
    BAND_TYPE CI-NEB
    NUMBER_OF_REPLICA 7
    K_SPRING 0.05
    &CI_NEB
      NSTEPS_IT 5
    &END CI_NEB
    &OPTIMIZE_BAND
      OPT_TYPE DIIS
      &DIIS
        MAX_STEPS 200
      &END DIIS
    &END OPTIMIZE_BAND
    &REPLICA
      COORD_FILE_NAME MgO_img0.xyz
    &END REPLICA
    &REPLICA
      COORD_FILE_NAME MgO_img1.xyz
    &END REPLICA
    &REPLICA
      COORD_FILE_NAME MgO_img2.xyz
    &END REPLICA
    &REPLICA
      COORD_FILE_NAME MgO_img3.xyz
    &END REPLICA
    &REPLICA
      COORD_FILE_NAME MgO_img4.xyz
    &END REPLICA
    &REPLICA
      COORD_FILE_NAME MgO_img5.xyz
    &END REPLICA
    &REPLICA
      COORD_FILE_NAME MgO_img6.xyz
    &END REPLICA
  &END BAND
&END MOTION
