# ======================================================================
# poly-APC v2 — track only lightweight planning/context files.
# The heavy raw experimental data and poster sources (~2.6 GB) are kept
# LOCAL ONLY, so remote (Ultraplan / cloud) sessions stay small and no
# unpublished raw data is pushed off-box. The actual calculation workspace
# lives outside this repo (/CH/poly_v2/). Re-include deliberately if needed.
# ======================================================================

# --- Raw electrochemistry / instrument data dirs (hundreds of MB each) ---
MgMg/
MgCu/
MgMo6S8_0.5C_cycle/
MgMo6S8_1C_cycle/
Aurbach_Coulombic_Efficiency/
critical_current_density/
Mg_transference_number/

# --- Posters, previews, requirements (large binaries) ---
Previous_posters/
_tmp_preview/
poster_requirements/

# --- Binary / large file types anywhere in the tree ---
*.cex
*.icex
*.mdat
*.VGD
*.vgd
*.rar
*.zip
*.7z
*.iso
*.pdf
*.doc
*.docx
*.ppt
*.pptx
*.xls
*.xlsx
*.tif
*.tiff
*.bmp
*.png
*.jpg
*.jpeg
*.psd
*.ai

# --- Large MD / simulation binaries (small .pdb/.xyz seeds are KEPT) ---
*.gro
*.itp
*.top
*.tpr
*.trr
*.xtc
*.edr
*.cpt
*.ndx
*.wfn
*.chk
*.fchk

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
*~
__pycache__/
*.pyc

# --- Deliberately re-include the v2 deliverable figures (small PNGs, versioned) ---
!computational_v2/results/figures/
!computational_v2/results/figures/*.png
computational_v2/mlff/*scaffold*.xyz

# --- MLFF working artifacts (derived/large; keep scripts + TRAIN_REPORT.md only) ---
computational_v2/mlff/run_*/
computational_v2/mlff/mlff_*train.xyz
computational_v2/mlff/mlff_*test.xyz
computational_v2/mlff/dataset_train_*.xyz
computational_v2/mlff/md_*start.xyz
computational_v2/mlff/md_bare_*
computational_v2/mlff/md_cmp_*
computational_v2/mlff/mp_finetuning-*.xyz
computational_v2/mlff/apc_*_valid_indices_*.txt
computational_v2/mlff/*.model
!computational_v2/mlff/models/
computational_v2/mlff/parity_forces.npz
computational_v2/mlff/eval_test.json
computational_v2/mlff/eval_bare.json
computational_v2/mlff/eval_poly.json
computational_v2/mlff/umb_*/
computational_v2/mlff/*_pmf.dat
