&GLOBAL
  PROJECT Cl2
  RUN_TYPE GEO_OPT
&END GLOBAL
&FORCE_EVAL
  METHOD QS
  &DFT
    UKS F
    MULTIPLICITY 1
    CHARGE 0
@INCLUDE '_hdr.inc'
  &END DFT
  &SUBSYS
    &CELL
      ABC 14.0 14.0 14.0
      PERIODIC XYZ
    &END CELL
    &COORD
      Cl 7.0 7.0 6.0
      Cl 7.0 7.0 8.0
    &END COORD
    &KIND Cl
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q7
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
&MOTION
  &GEO_OPT
    OPTIMIZER BFGS
    MAX_ITER 100
  &END GEO_OPT
&END MOTION
