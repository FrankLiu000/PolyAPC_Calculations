&GLOBAL
  PROJECT PON_geo
  RUN_TYPE GEO_OPT
  PRINT_LEVEL LOW
&END GLOBAL
&MOTION
  &GEO_OPT
    OPTIMIZER BFGS
    MAX_ITER 60
    MAX_FORCE 4.5E-4
  &END GEO_OPT
&END MOTION
&FORCE_EVAL
  METHOD QS
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    CHARGE 0
    &MGRID
      CUTOFF 400
      REL_CUTOFF 50
    &END MGRID
    &QS
      EPS_DEFAULT 1.0E-12
    &END QS
    &PRINT
      &MO
        EIGENVALUES .TRUE.
        OCCUPATION_NUMBERS .TRUE.
        &EACH
          QS_SCF 0
        &END EACH
      &END MO
    &END PRINT
    &SCF
      SCF_GUESS ATOMIC
      EPS_SCF 1.0E-6
      MAX_SCF 400
      ADDED_MOS 80
      &SMEAR ON
        METHOD FERMI_DIRAC
        ELECTRONIC_TEMPERATURE [K] 300
      &END SMEAR
      &DIAGONALIZATION ON
        ALGORITHM STANDARD
      &END DIAGONALIZATION
      &MIXING ON
        METHOD BROYDEN_MIXING
        ALPHA 0.3
        NBROYDEN 8
      &END MIXING
    &END SCF
    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
      &VDW_POTENTIAL
        POTENTIAL_TYPE PAIR_POTENTIAL
        &PAIR_POTENTIAL
          TYPE DFTD3
          PARAMETER_FILE_NAME dftd3.dat
          REFERENCE_FUNCTIONAL PBE
        &END PAIR_POTENTIAL
      &END VDW_POTENTIAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      A 4.805695 0.000000 0.000000
      B -2.402848 4.161854 0.000000
      C 0.000000 0.000000 5.293055
      PERIODIC XYZ
    &END CELL
    &COORD
      P 2.19879 -0.00205 1.75945
      P -1.10117 1.90318 3.53361
      P 1.30085 2.25314 0.00000
      N 1.22519 1.17686 1.23749
      O 3.18241 0.47615 2.98293
      N 2.81170 2.50323 4.77949
      O 0.40660 1.64948 4.05557
      N -1.17885 2.99412 2.31012
      O 0.76201 3.68662 0.51356
      SCALED F
    &END COORD
    &KIND "P"
      BASIS_SET "DZVP-MOLOPT-SR-GTH"
      POTENTIAL "GTH-PBE-q5"
    &END KIND
    &KIND "N"
      BASIS_SET "DZVP-MOLOPT-SR-GTH"
      POTENTIAL "GTH-PBE-q5"
    &END KIND
    &KIND "O"
      BASIS_SET "DZVP-MOLOPT-SR-GTH"
      POTENTIAL "GTH-PBE-q6"
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
