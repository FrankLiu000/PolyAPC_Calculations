&END FORCE_EVAL
&MOTION
  &GEO_OPT
    OPTIMIZER BFGS
    MAX_ITER 80
    MAX_FORCE 1.0E-3
    &BFGS
      TRUST_RADIUS [bohr] 0.15
    &END BFGS
  &END GEO_OPT
  &CONSTRAINT
    &FIXED_ATOMS
      LIST 1..64
    &END FIXED_ATOMS
  &END CONSTRAINT
&END MOTION
